# Copy this file to backend/.env and fill in real values before running locally.
# Spring Boot does not read .env files natively — see "How to load this" below.

# ---- Database ----
DB_USERNAME=root
DB_PASSWORD=root

# ---- Auth ----
# Use a long, random string in any real deployment (this default is dev-only).
JWT_SECRET=this-is-a-dev-only-secret-key-please-change-me-before-deploying-1234567890

# ---- CORS ----
# Origin the frontend is served from.
CORS_ORIGIN=http://localhost:5173

# ---- AI Chat Assistant (optional, "Good to Have" feature) ----
# Free key, no billing required: https://aistudio.google.com/apikey
# Leave blank to disable — the /api/ai/chat and /api/ai/summary endpoints
# will respond gracefully instead of erroring.
GEMINI_API_KEY=

# ---- How to load this ----
# Option A (shell, macOS/Linux):
#   export $(grep -v '^#' .env | xargs) && mvn spring-boot:run
#
# Option B (Docker Compose): reference "env_file: .env" under the backend
# service if you containerize the API — see the commented example in
# docker-compose.yml at the project root.
#
# Option C (IDE): most IDEs (IntelliJ, VS Code) can load a .env file directly
# in the run configuration — no extra dependency needed.
